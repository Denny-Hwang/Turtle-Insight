# Turtle Insight — environment template (TDD §8).
# Copy to `.env` and fill in. NEVER commit the real `.env` (see .gitignore).

# --- LLM tiers (model identifiers via env only; no hardcoded model names) ---
TI_DEEP_MODEL=            # Claude model id for deep tier (thesis synthesis, RedTeam, briefings)
TI_FAST_MODEL=            # optional local model id; falls back to deep tier if empty
ANTHROPIC_API_KEY=        # secret

# --- storage ---
TI_DB_URL=sqlite:///ti.db # v1+: postgres://...
TI_REDIS_URL=             # v1+ (Dramatiq broker)
TI_OLLAMA_URL=            # optional local fast-tier endpoint (e.g. http://localhost:11434)
TI_API_TOKEN=             # optional local API token (sent as X-API-Token header)

# --- data source keys (secrets) ---
DART_API_KEY=
FRED_API_KEY=
MARKET_API_KEY=

# --- connectors (ADR-0010) ---
TI_CONNECTOR_MODE=fixture # "live" fetches from public gov APIs (EDGAR/FRED); default replays fixtures
TI_EDGAR_USER_AGENT=      # required for live EDGAR (SEC fair-access), e.g. "turtle-insight you@example.com"
TI_EDGAR_TICKERS=         # comma-separated US tickers to watch, e.g. NVDA,MSFT
TI_FRED_SERIES=           # comma-separated FRED series ids, e.g. CES4422000001,DFF
TI_CACHE_DIR=.cache       # offline-resilience cache for live connectors
TI_HTTP_TIMEOUT=10        # seconds, live connector calls
